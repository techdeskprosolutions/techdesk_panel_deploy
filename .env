# ============================================================
# homelab-core Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Edit .env and fill in ALL values marked below
# 3. NEVER commit your real .env file to git (add it to .gitignore)
#
# Generate strong passwords easily:
#   openssl rand -base64 32
#   or use a password manager / https://www.lastpass.com/password-generator
# ============================================================

# ------------------------------------------------------------
# MariaDB Root Password
# ------------------------------------------------------------
# !!! CHANGE THIS - USE A LONG STRONG UNIQUE PASSWORD (20+ chars) !!!
DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_HERE

# Optional pre-created database name (uncomment in compose if you want this)
# DB_NAME=homelab

# ------------------------------------------------------------
# WireGuard Easy Configuration
# ------------------------------------------------------------
# WG_HOST: Your server's public IP or domain name (used in client configs)
#          Use a domain if you have one pointed at your server.
WG_HOST=YOUR_PUBLIC_IP_OR_DOMAIN_HERE

# !!! CHANGE THIS - STRONG PASSWORD TO PROTECT THE wg-easy WEB UI !!!
WG_PASSWORD=REPLACE_WITH_ANOTHER_STRONG_PASSWORD_HERE

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
# - After first deployment, change the default NPM admin password immediately.
# - Create an NPM "Access List" with your home public IP + the WireGuard client subnet
#   (usually starts with 10.8.0.0/24 — check inside wg-easy UI after setup).
# - All admin interfaces should use that Access List.
# ============================================================
